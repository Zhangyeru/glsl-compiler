#version 450
layout(local_size_x = 64) in;

layout(std430, binding = 0) buffer Buf {
  float data[];
} buf;

shared float tile[64];

void main() {
  uint gid = gl_GlobalInvocationID.x;
  uint lid = gl_LocalInvocationID.x;

  tile[lid] = buf.data[gid];
  barrier();

  buf.data[gid] = tile[63u - lid];
}

#version 450
layout(local_size_x = 8, local_size_y = 8, local_size_z = 1) in;

layout(std430, binding = 0) buffer Buf {
  float data[];
} buf;

void main() {
  uint x = gl_GlobalInvocationID.x;
  uint y = gl_GlobalInvocationID.y;
  uint width = 512u;
  uint idx = y * width + x;

  float v = buf.data[idx];
  buf.data[idx] = v * 0.5 + 0.25;
}

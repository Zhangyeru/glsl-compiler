+std::string GetShaderPathFromFunction(const Function &function) {
+    const auto &subFunc = function.rootFunc_->programs_[0];
+    auto leafFuncAttr = subFunc->GetLeafFuncAttribute();
+    ASSERT(leafFuncAttr != nullptr);
+    std::string binPath = leafFuncAttr->binPath;
+    ASSERT(!binPath.empty());
+    return binPath.substr(0, binPath.rfind('.')) + ".comp";
+}
+
+std::string GetSpirvPathFromFunction(const Function &function) {
+    const auto &subFunc = function.rootFunc_->programs_[0];
+    auto leafFuncAttr = subFunc->GetLeafFuncAttribute();
+    ASSERT(leafFuncAttr != nullptr);
+    return leafFuncAttr->binPath;
+}
+
+std::string GetResultFromShader(const Function &function) {
+    std::string shaderFile = GetShaderPathFromFunction(function);
+    std::ifstream ifs(shaderFile);
+    std::string res((std::istreambuf_iterator<char>(ifs)), (std::istreambuf_iterator<char>()));
+    ifs.close();
+    return res;
+}

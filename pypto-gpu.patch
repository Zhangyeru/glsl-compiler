+};
+
+TEST_F(TestCodegenGpuVk, TestFactoryDispatchAddShaderGeneration) {
+    std::vector<int64_t> shape = {64, 64};
+    Tensor inputA(DT_FP32, shape, "A");
+    Tensor inputB(DT_FP32, shape, "B");
+    Tensor output(DT_FP32, shape, "C");
+
+    FUNCTION("GPU_VK_ADD", {inputA, inputB, output}) {
+        output = Add(inputA, inputB);
+    }
+
+    auto function = Program::GetInstance().GetFunctionByRawName(FUNCTION_PREFIX + std::string("GPU_VK_ADD"));
+    ASSERT_NE(function, nullptr);
+
+    CodeGen codegen(CodeGenCtx{});
+    codegen.GenCode(*function, {});
+
+    std::string shader = GetResultFromShader(*function);
+    CheckStringExist("#version 450", shader);
+    CheckStringExist("layout(local_size_x = 256", shader);
+    CheckStringExist("layout(push_constant) uniform PushConstants", shader);
+    CheckStringExist("buf_A_", shader);
+    CheckStringExist("buf_B_", shader);
+    CheckStringExist("buf_C_", shader);
+    CheckStringExist("gl_GlobalInvocationID.x", shader);
+    CheckStringExist("pc.numel", shader);
+    CheckStringExist(" + ", shader);
+}
+
+TEST_F(TestCodegenGpuVk, TestWhereShaderGeneration) {
+    std::vector<int64_t> shape = {32, 32};
+    Tensor condition(DT_BOOL, shape, "Cond");
+    Tensor inputA(DT_FP32, shape, "A");
+    Tensor inputB(DT_FP32, shape, "B");
+    Tensor output(DT_FP32, shape, "Out");
+
+    FUNCTION("GPU_VK_WHERE", {condition, inputA, inputB, output}) {
+        output = Where(condition, inputA, inputB);
+    }
+
+    auto function = Program::GetInstance().GetFunctionByRawName(FUNCTION_PREFIX + std::string("GPU_VK_WHERE"));
+    ASSERT_NE(function, nullptr);
+
+    CodeGen codegen(CodeGenCtx{});
+    codegen.GenCode(*function, {});
+
+    std::string shader = GetResultFromShader(*function);
+    CheckStringExist("buf_Cond_", shader);
+    CheckStringExist(" != 0u", shader);
+    CheckStringExist(" ? ", shader);
+    CheckStringExist(" : ", shader);
+}
+
+TEST_F(TestCodegenGpuVk, TestSpirvCompileWhenCompilerAvailable) {
+    if (CodeGenGpuVk::DetectShaderCompiler().empty()) {
+        GTEST_SKIP() << "glslangValidator/glslc is not available in PATH";
+    }
+
+    std::vector<int64_t> shape = {16, 16};
+    Tensor inputA(DT_FP32, shape, "A");
+    Tensor inputB(DT_FP32, shape, "B");
+    Tensor output(DT_FP32, shape, "C");
+
+    FUNCTION("GPU_VK_COMPILE", {inputA, inputB, output}) {
+        output = Mul(inputA, inputB);
+    }
+
+    auto function = Program::GetInstance().GetFunctionByRawName(FUNCTION_PREFIX + std::string("GPU_VK_COMPILE"));
+    ASSERT_NE(function, nullptr);
+
+    CodeGen codegen(CodeGenCtx{});
+    codegen.GenCode(*function, {});
+
+    std::string spirvPath = GetSpirvPathFromFunction(*function);
+    EXPECT_FALSE(RealPath(spirvPath).empty()) << "Expected SPIR-V binary at " << spirvPath;
+    EXPECT_GT(GetFileSize(spirvPath), 0u);
+}

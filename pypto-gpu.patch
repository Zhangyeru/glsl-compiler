+class TestCodegenGpuVk : public ::testing::Test {
+public:
+    void SetUp() override {
+        Program::GetInstance().Reset();
+        config::Reset();
+        config::SetBuildStatic(true);
+        config::SetHostOption(COMPILE_STAGE, CS_EXECUTE_GRAPH);
+        config::SetPlatformConfig(KEY_ENABLE_COST_MODEL, false);
+        oldArch_ = Platform::Instance().GetSoc().GetNPUArch();
+        Platform::Instance().GetSoc().SetNPUArch(NPUArch::GPU_VK);
